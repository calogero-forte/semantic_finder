# ── MCP Server ────────────────────────────────────────────────────────────────
# Server name
MCP_NAME=semantic_finder_mcp
# Port the server listens on (default: 8001)
MCP_PORT=8001

# MCP spec OAuth 2.0 authentication.
# Set to a secret value to enable auth. This value is the CONSENT PAGE PASSWORD —
# when a new MCP client tries to connect, your browser shows a page asking you to
# type it before approving the connection. Once approved, the client stores a
# refresh token and reconnects silently. When enabled, FastMCP exposes:
#   /.well-known/oauth-authorization-server  OAuth discovery
#   /register                                dynamic client registration
#   /authorize → /oauth/consent              browser consent page
#   /token                                   code ↔ access+refresh tokens
# MCP clients (Claude Code, VS Code, MCP Inspector) discover and complete the
# flow automatically. Leave empty to run without auth (local development).
MCP_AUTH_TOKEN=

# Path to persist MCP OAuth state (registered clients + refresh tokens) across restarts.
# Default: credentials/oauth_state.json — delete this file to force all clients to re-authenticate.
MCP_OAUTH_STATE_PATH=./credentials/oauth_state.json

# ── File System ────────────────────────────────────────────────────────────────
#File System paths that MCP server can access
LOCAL_PATHS=~/Local_database


